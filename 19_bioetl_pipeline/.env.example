# Copy to .env and fill in real values — never commit .env
DATABASE_URL=postgresql://etl_user:changeme@localhost:5432/bioetl_db

# Public API base URLs (defaults shown; override if endpoints change)
OAS_BASE_URL=http://opig.stats.ox.ac.uk/webapps/oas/api
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data
UNIPROT_BASE_URL=https://rest.uniprot.org/uniprotkb

# Pipeline behaviour
REQUEST_TIMEOUT=30
BATCH_SIZE=100
LOG_LEVEL=INFO
LOG_FORMAT=console
