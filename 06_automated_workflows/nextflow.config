/*
 * Nextflow Configuration — RNA-seq Aging Pipeline
 * Resource definitions for local, SLURM HPC, and AWS profiles
 */

manifest {
    name        = "rnaseq-aging"
    description = "Automated RNA-seq pipeline for aging research"
    version     = "1.0.0"
    nextflowVersion = ">=23.04"
}

// ── Default process settings ───────────────────────────────────────────────────

process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? "retry" : "terminate" }
    maxRetries    = 3
    maxErrors     = "-1"

    withLabel: low_cpu {
        cpus   = 2
        memory = "4.GB"
        time   = "1.h"
    }
    withLabel: medium_cpu {
        cpus   = 4
        memory = "16.GB"
        time   = "4.h"
    }
    withLabel: high_cpu {
        cpus   = 8
        memory = "64.GB"
        time   = "12.h"
    }
}

// ── Profiles ──────────────────────────────────────────────────────────────────

profiles {

    local {
        process.executor = "local"
        conda.enabled    = true
    }

    slurm {
        process {
            executor = "slurm"
            queue    = "standard"
            clusterOptions = "--account=aging_proj"
        }
        conda.enabled = true
        executor {
            queueSize   = 100
            submitRateLimit = "10/1min"
        }
    }

    aws {
        process.executor = "awsbatch"
        aws {
            region     = "eu-west-1"
            batch.cliPath = "/usr/local/bin/aws"
        }
        docker.enabled = true
        process.container = "rnaseq-aging:latest"
    }

    docker {
        docker.enabled    = true
        docker.runOptions = "-u \$(id -u):\$(id -g)"
        process.container = "rnaseq-aging:latest"
    }

    test {
        // Small test dataset for CI/CD
        params.reads = "${baseDir}/test_data/*_{R1,R2}.fastq.gz"
        process {
            withLabel: high_cpu { cpus = 2; memory = "8.GB" }
        }
    }
}

// ── Reporting ─────────────────────────────────────────────────────────────────

report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_timeline.html"
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_dag.html"
}
